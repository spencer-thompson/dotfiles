# Search case-insensitively if pattern is all lowercase.
--smart-case

# # Highlight matches.
# --colors=match:fg:225,18,153

# --smart-case
--hidden

--glob=!.git/**
--glob=!node_modules/**
--glob=!dist/**
--glob=!build/**
--glob=!coverage/**
--glob=!target/**
--glob=!vendor/**

--glob=!*.min.js
--glob=!*.map

--max-columns=240
--max-columns-preview
