{
  "$schema": "https://opencode.ai/config.json",
  // "model": "anthropic/claude-sonnet-4-20250514",
  "model": "openai/gpt-5.5-fast",
  "autoshare": false,
  "autoupdate": true,
  "agent": {
    "review": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent",
      // "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
      "tools": {
        "write": false,
        "edit": false,
      },
    },
    // "general": {
    //   "mode": "primary",
    //   "prompt": "You are a helpful assistant",
    //   "tools": {
    //     "write": false,
    //     "edit": false,
    //     "bash": true,
    //     "read": true,
    //     "grep": true,
    //     "glob": true,
    //     "codex": true,
    //   },
    // },
    // "docs": {
    //   "mode": "primary",
    //   "prompt": "{file:./prompts/documentation.txt}",
    //   "tools": {
    //     "write": true,
    //     "edit": true,
    //     "bash": false,
    //     "read": true,
    //     "grep": true,
    //     "glob": true,
    //   },
    // },
    "search": {
      "mode": "subagent",
      "prompt": "Use codex to search the web.",
      "tools": {
        "edit": false,
        "bash": true,
        "read": true,
        "grep": true,
        "glob": true,
        "codex": true,
        "webfetch": false,
        "websearch": false,
      },
    },

    // "search": {
    //   "mode": "subagent",
    //   "prompt": "Use codex review code for best practices and potential issues.",
    //   "tools": {
    //     "edit": false,
    //     "bash": true,
    //     "read": true,
    //     "grep": true,
    //     "glob": true,
    //     "codex": true,
    //     "webfetch": "deny",
    //     "websearch": "deny",
    //   },
    // },
  },
  "mcp": {
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?read_only=true",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:OUTRIVAL_SUPABASE_READ_ONLY_TOKEN}",
      },
      // "environment": {
      //   "SUPABASE_ACCESS_TOKEN": "{env:OUTRIVAL_SUPABASE_READ_ONLY_TOKEN}",
      // },
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true,
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/",
      "enabled": false,
    },

    "codex": {
      "type": "local",
      "command": ["codex", "mcp-server"],
      "enabled": true,
      "timeout": 300000,
    },
    "openai_docs": {
      "type": "remote",
      "url": "https://developers.openai.com/mcp",
    },
  },
  "plugin": ["@tarquinen/opencode-dcp@latest"],
}
